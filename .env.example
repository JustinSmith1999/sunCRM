# Required for the web app. Copy to .env (or set in Netlify dashboard).
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Required only for scripts/bulk-create-users.mjs (admin-only ops).
# DO NOT add this in Netlify — service-role bypasses RLS and the web app must never have it.
# Generate at Supabase Dashboard → Project Settings → API → service_role.
SUPABASE_SERVICE_ROLE_KEY=eyJ...
